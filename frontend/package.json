{
  "name": "frontend",
  "version": "0.2.55",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:frontend": "node dist/frontend/server/server.mjs",
    "format": "prettier --write \"src/**/*.{ts,js,scss,css,html,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,js,scss,css,html,json,md}\""
  },
  "private": true,
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "arrowParens": "always",
    "endOfLine": "lf"
  },
  "dependencies": {
    "@angular/animations": "^20.3.13",
    "@angular/common": "^20.3.13",
    "@angular/compiler": "^20.3.13",
    "@angular/core": "^20.3.13",
    "@angular/forms": "^20.3.19",
    "@angular/platform-browser": "^20.3.13",
    "@angular/platform-browser-dynamic": "^20.3.19",
    "@angular/platform-server": "^20.3.19",
    "@angular/router": "^20.3.19",
    "@angular/ssr": "^20.3.24",
    "@primeng/themes": "^20.4.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "express": "^4.22.1",
    "file-saver": "^2.0.5",
    "nodemailer": "^8.0.5",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^20.4.0",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.24",
    "tslib": "^2.8.1",
    "xlsx": "^0.18.5",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.24",
    "@angular/cli": "^20.3.24",
    "@angular/compiler-cli": "^20.3.19",
    "@types/express": "^4.17.25",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.19.130",
    "baseline-browser-mapping": "^2.10.21",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3"
  }
}
